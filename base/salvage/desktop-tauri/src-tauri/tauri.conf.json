{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "FluxSQL Desktop",
  "version": "0.1.0",
  "identifier": "com.fluxsql.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "windows": [
      {
        "title": "FluxSQL Desktop",
        "width": 800,
        "height": 600,
        "visible": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "externalBin": [
      "binaries/cdcart-backend"
    ]
  }
}
