{
  "name": "fluxy-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Fluxy monorepo for web, desktop, local sidecar, skills and agent bridge.",
  "scripts": {
    "dev:web": "pnpm --filter @fluxy/web dev",
    "dev:api": "pnpm --filter @fluxy/api dev",
    "dev:desktop": "pnpm --filter @fluxy/desktop desktop:dev",
    "dev:local-sidecar": "python apps/desktop/backend-python/main.py",
    "build:web": "pnpm --filter @fluxy/web build",
    "build:api": "pnpm --filter @fluxy/api build",
    "build:desktop": "pnpm --filter @fluxy/desktop desktop:build",
    "lint:web": "pnpm --filter @fluxy/web lint",
    "lint:api": "pnpm --filter @fluxy/api lint",
    "typecheck": "pnpm --recursive --if-present run lint",
    "verify:mvp": "powershell -ExecutionPolicy Bypass -File scripts/verify-mvp.ps1"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.7.0"
}
